# BrazilFinance API - Environment Configuration

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Cache (Redis - opcional)
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FREE_TIER=500
RATE_LIMIT_PRO_TIER=10000

# API Keys Management
API_KEYS_FILE=api_keys.json

# External APIs Timeouts
BCB_TIMEOUT=15
YAHOO_TIMEOUT=10
TESOURO_TIMEOUT=30

# Logging
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=brazilfinance.log

# CORS
CORS_ORIGINS=*

# Development
DEBUG=false
RELOAD=false